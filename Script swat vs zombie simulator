task.spawn(function()
    local Lang1 = Vector3.new(-44.32, 32.00, 2715.94)
    local Chinh = Vector3.new(-380.83, 55.50, 4942.56)
    
    while true do
        task.wait(1)
        if _G.AutoFarm then
            -- Tự động bật kèm các tính năng bổ trợ để farm không chết
            _G.KillAura = true
            _G.AntiAFK = true
            
            -- Bước 1: Kiểm tra súng trước khi bắt đầu hành trình di chuyển
            checkAndEquipWeapon()
            
            -- Bước 2: Bắt đầu bay Tween tới Làng 1 với tốc độ 250
            if _G.AutoFarm then
                tweenTo(Lang1, 250)
            end
            
            -- Đứng im tại Làng 1 trong 30 giây để sấy Aura dọn quái
            local secondsLeft = 30
            while secondsLeft > 0 and _G.AutoFarm do
                checkAndEquipWeapon() -- Đảm bảo luôn cầm súng trên tay xuyên suốt
                task.wait(1)
                secondsLeft = secondsLeft - 1
            end
            
            -- Bước 3: Bay Tween từ Làng 1 tiến đến Tọa độ Làng Chính
            if _G.AutoFarm then
                tweenTo(Chinh, 250)
            end
            
   
