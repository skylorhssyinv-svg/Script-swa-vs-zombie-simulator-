------------------------------------------------------------------------
-- ⚙️ LÕI ĐIỀU KHIỂN CHUYỂN ĐỘNG TWEEN CỐ ĐỊNH SPEED 200-500
------------------------------------------------------------------------
local function tweenTo(targetPos, speedValue)
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local distance = (hrp.Position - targetPos).Magnitude
    local calculatedDuration = distance / speedValue
    
    -- Tạo lực kéo BodyVelocity chống rớt hoặc rung lắc vật lý khi bay xuyên map
    local bv = Instance.new("BodyVelocity")
    bv.Velocity = Vector3.new(0, 0, 0)
    bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
    bv.Parent = hrp
    
    local tweenInfo = TweenInfo.new(calculatedDuration, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(hrp, tweenInfo, {CFrame = CFrame.new(targetPos)})
    tween:Play()
    tween.Completed:Wait()
    
    bv:Destroy()
end

------------------------------------------------------------------------
-- 🛡️ LÕI AUTO WEAPON BUYER & EQUIPPER (KIỂM TRA VŨ KHÍ SAU REBIRTH)
------------------------------------------------------------------------
local function checkAndEquipWeapon()
    local char = LocalPlayer.Character
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    
    local hasWeapon = false
    -- Kiểm tra xem trên người hoặc trong balo có khẩu súng nào không
    if char then
        for _, v in ipairs(char:GetChildren()) do
            if v:IsA("Tool") then hasWeapon = true break end
        end
    end
    if not hasWeapon and backpack then
        for _, v in ipairs(backpack:GetChildren()) do
            if v:IsA("Tool") then
                hasWeapon = true
                -- Nếu súng nằm trong balo, tự động lôi ra tay cầm luôn
                v.Parent = char
                break
            end
        end
    end
    
    -- Nếu không phát hiện có súng (vừa Rebirth xong bị xóa sạch vũ khí)
    if not hasWeapon then
        pcall(function()
            -- Gửi gói tin mua vũ khí hồi sinh tự động (Thử mua HK416 trước, nếu không được mua Barrett)
            game:GetService("ReplicatedStorage").ShopRemote:FireServer("equipRebirthWeapon", "HK416BUY")
            task.wait(0.5)
            game:GetService("ReplicatedStorage").ShopRemote:FireServer("equipRebirthWeapon", "BarrettBUY")
            task.wait(0.5)
            
            -- Lôi vũ khí mới mua ra tay cầm ngay lập tức
            if backpack then
                local newTool = backpack:FindFirstChildOfClass("Tool")
                if newTool and char then
                    newTool.Parent = char
                end
            end
        end)
    end
end

